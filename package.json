{
  "name": "@svey-xyz/simple-shader-component",
  "author": "svey",
  "description": "Zero dependency shader component",
  "keywords": [
    "glsl",
    "shader",
    "component",
    "webgl",
    "react"
  ],
  "version": "1.2.4",
  "license": "GPL-3.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/core/index.cjs",
  "module": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svey-xyz/simple-shader-component.git"
  },
  "bugs": {
    "url": "https://github.com/svey-xyz/simple-shader-component/issues"
  },
  "homepage": "https://github.com/svey-xyz/simple-shader-component#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@types/bun": "^1.1.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:core": "bun test test/core",
    "test:react": "bun test test/react",
    "clean": "rm -rf dist",
    "build:library": "bun ./build.ts",
    "build:types": "bunx tsc",
    "build": "bun run clean && bun build:library && bun build:types && cp -R ./src/types ./dist/types"
  }
}
